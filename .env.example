# ==============================
# Django Core
# ==============================
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
DJANGO_ENV=dev
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_ADMIN_URL=admin/

# ==============================
# Database
# For production, prefer PostgreSQL engine
# ==============================
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=backend/db.sqlite3
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=127.0.0.1
DJANGO_DB_PORT=5432
DJANGO_DB_CONN_MAX_AGE=60
DJANGO_DB_SSLMODE=prefer

# ==============================
# CORS/CSRF
# ==============================
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True
CSRF_TRUSTED_ORIGINS_ADDRESS=http://localhost:5173,http://127.0.0.1:5173

# ==============================
# DRF Throttling / Rate Limits
# ==============================
DRF_THROTTLE_ANON=100/day
DRF_THROTTLE_USER=1000/day
DRF_THROTTLE_LOGIN=10/min
RATELIMIT_ENABLE=True
BLOCKED_IPS=

# ==============================
# JWT
# ==============================
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=False
JWT_AUTH_HEADER_TYPES=Bearer
JWT_SIGNING_KEY=

# ==============================
# Email
# ==============================
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True
DJANGO_EMAIL_USE_SSL=False
DJANGO_DEFAULT_FROM_EMAIL=no-reply@example.com

# ==============================
# Production Security
# ==============================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
CSRF_COOKIE_HTTPONLY=True

# ==============================
# Optional third-party keys
# ==============================
THIRD_PARTY_API_KEY=
OPENAI_API_KEY=

# ==============================
# Frontend compatibility variable
# ==============================
VITE_API_URL=http://127.0.0.1:8000
