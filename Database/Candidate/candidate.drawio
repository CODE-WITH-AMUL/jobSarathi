            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;erDiagram\n    User ||--|| CandidateProfile : has_one\n    CandidateProfile ||--o{ Resume : has\n    CandidateProfile ||--o{ Education : has\n    CandidateProfile ||--o{ Skill : has\n    CandidateProfile ||--o{ Experience : has\n    CandidateProfile ||--o{ JobApplication : submits\n    CandidateProfile ||--o{ SavedJob : saves\n    CandidateProfile }o--|| SocialMedia : has_optional\n    \n    Job ||--o{ JobApplication : receives\n    Job ||--o{ SavedJob : saved_by\n    \n    %% Core Entities\n    User {\n        int id PK\n        string username\n        string email\n        string password\n        datetime date_joined\n        boolean is_active\n        boolean is_staff\n    }\n    \n    CandidateProfile {\n        int id PK\n        int user_id FK\n        string first_name\n        string last_name\n        string email UK\n        string phone UK\n        text address\n        string city\n        string state\n        string country\n        string zip_code\n        string pincode\n        date dob\n        int age\n        string gender\n        image profile_picture\n        file resume\n        text taglines\n        text description\n        url portfolio\n        int social_media_id FK\n        datetime created_at\n        datetime updated_at\n    }\n    \n    SocialMedia {\n        int id PK\n        url facebook\n        url instagram\n        url twitter\n        url linkedin\n        url youtube\n        url tiktok\n        url reddit\n        url pinterest\n        url github\n        url website\n        url other\n    }\n    \n    Resume {\n        int id PK\n        int candidate_id FK\n        file file\n        string title\n        boolean is_active\n        datetime created_at\n        datetime updated_at\n    }\n    \n    Education {\n        int id PK\n        int candidate_id FK\n        string degree\n        string institution\n        string field_of_study\n        date start_date\n        date end_date\n        text description\n        boolean is_current\n        boolean is_verified\n        boolean is_active\n        datetime created_at\n        datetime updated_at\n    }\n    \n    Skill {\n        int id PK\n        int candidate_id FK\n        string skill\n        string slug UK\n        text description\n        boolean is_current\n        boolean is_verified\n        boolean is_active\n        datetime created_at\n        datetime updated_at\n    }\n    \n    Experience {\n        int id PK\n        int candidate_id FK\n        string company\n        string position\n        text description\n        boolean is_current\n        boolean is_verified\n        boolean is_active\n        datetime created_at\n        datetime updated_at\n    }\n    \n    Job {\n        int id PK\n        string title\n        text description\n        string location\n        string type\n        string experience_level\n        int salary_min\n        int salary_max\n        string currency\n        int company_id FK\n        datetime posted_at\n        datetime deadline\n        boolean is_active\n    }\n    \n    JobApplication {\n        int id PK\n        int candidate_id FK\n        int job_id FK\n        string status\n        string source\n        text cover_letter\n        file resume_file\n        int resume_match_score\n        text resume_analysis\n        datetime created_at\n        datetime updated_at\n    }\n    \n    SavedJob {\n        int id PK\n        int candidate_id FK\n        int job_id FK\n        datetime created_at\n        datetime updated_at\n    }\n    \n    %% Relationships with Cardinality\n    User ||--|| CandidateProfile : \&quot;1:1\\n(OneToOne)\&quot;\n    CandidateProfile ||--o{ Resume : \&quot;1:N\\n(One-to-Many)\&quot;\n    CandidateProfile ||--o{ Education : \&quot;1:N\\n(One-to-Many)\&quot;\n    CandidateProfile ||--o{ Skill : \&quot;1:N\\n(One-to-Many)\&quot;\n    CandidateProfile ||--o{ Experience : \&quot;1:N\\n(One-to-Many)\&quot;\n    CandidateProfile ||--o{ JobApplication : \&quot;1:N\\n(One-to-Many)\&quot;\n    CandidateProfile ||--o{ SavedJob : \&quot;1:N\\n(One-to-Many)\&quot;\n    CandidateProfile }o--|| SocialMedia : \&quot;N:1\\n(Many-to-One)\&quot;\n    \n    Job ||--o{ JobApplication : \&quot;1:N\\n(One-to-Many)\&quot;\n    Job ||--o{ SavedJob : \&quot;1:N\\n(One-to-Many)\&quot;\n    \n    %% Unique Constraints\n    CandidateProfile {\n        string email UK \&quot;Unique Email\&quot;\n        string phone UK \&quot;Unique Phone\&quot;\n    }\n    \n    Skill {\n        string slug UK \&quot;Unique Slug\&quot;\n    }\n    \n    JobApplication {\n        string job_candidate UK \&quot;Unique Together: (job, candidate)\&quot;\n    }\n    \n    SavedJob {\n        string candidate_job UK \&quot;Unique Together: (candidate, job)\&quot;\n    }&quot;&#xa;}" id="2">
